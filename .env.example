# Database (Neon Postgres)
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# E2E Testing (Playwright) — create a test user in Clerk Dashboard
# E2E_CLERK_USER_USERNAME="test@example.com"
# E2E_CLERK_USER_PASSWORD="your-test-password"

# Cloudflare R2
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME=""

# Encryption (Phase 4 — for encrypting API keys at rest)
ENCRYPTION_SECRET="your-secret-key-at-least-32-characters-long"
